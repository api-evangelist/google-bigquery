{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/TableDataInsertAllResponse",
  "title": "TableDataInsertAllResponse",
  "type": "object",
  "properties": {
    "kind": {
      "type": "string",
      "description": "The resource type"
    },
    "insertErrors": {
      "type": "array",
      "items": {
